DATABASE_URL=postgresql://cdr:cdr_password@localhost:5432/callmanager

# AXL Enrichment — up to 5 clusters, matched by CUCM Enterprise Parameter "Cluster ID"
# Cluster 1
AXL_HOST_1=cucm-pub1.example.com
AXL_USERNAME_1=axl-user
AXL_PASSWORD_1=axl-password
AXL_VERSION_1=15.0
AXL_CLUSTER_ID_1=ohsuCUCMprod

# Cluster 2
#AXL_HOST_2=cucm-pub2.example.com
#AXL_USERNAME_2=axl-user
#AXL_PASSWORD_2=axl-password
#AXL_VERSION_2=14.0
#AXL_CLUSTER_ID_2=cucmOHSUtest

# Cache TTL in seconds (default: 86400 = 24 hours)
#AXL_CACHE_TTL=86400

CDR_INCOMING_DIR=/data/incoming
CDR_RETENTION_DAYS=90
MCP_PORT=3000
LOG_LEVEL=info
